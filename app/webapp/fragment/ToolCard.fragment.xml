<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="toolDetailDialog"
        title="{mcp>name}"
        contentWidth="480px">
        <content>
            <VBox class="sapUiSmallMargin">
                <Text text="{mcp>description}" class="sapUiSmallMarginBottom" />
                <ObjectStatus
                    text="Category: {mcp>category}"
                    state="Information"
                    class="sapUiSmallMarginBottom" />
                <List
                    headerText="Parameters"
                    items="{mcp>parameters}"
                    noDataText="No parameters">
                    <StandardListItem
                        title="{mcp>name}"
                        description="Type: {mcp>type}"
                        info="{= ${mcp>required} ? 'Required' : 'Optional'}"
                        infoState="{= ${mcp>required} ? 'Warning' : 'Success'}"
                        icon="{= ${mcp>required} ? 'sap-icon://sys-enter-2' : 'sap-icon://hint'}" />
                </List>
            </VBox>
        </content>
        <endButton>
            <Button text="Close" press=".onCloseToolDialog" />
        </endButton>
    </Dialog>

</core:FragmentDefinition>
