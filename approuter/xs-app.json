{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/tm/(.*)$",
      "target": "/tm/$1",
      "destination": "tm-api-layer",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/mcp/(.*)$",
      "target": "/$1",
      "destination": "tm-mcp-server",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "localDir": "resources",
      "authenticationType": "xsuaa"
    }
  ]
}
